# Chat UI base URL (Astro dev server)
PLAYWRIGHT_BASE_URL=http://localhost:4321

# Backend health check for integration tests
PLAYWRIGHT_BACKEND_HEALTH_URL=http://localhost:8000/health

# Set to 1 to auto-start Astro dev server before tests (default: use `make dev` / `make dev-frontend`)
# PLAYWRIGHT_START_WEB_SERVER=1
