DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentos_chat
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_ISSUER=https://your-tenant.us.auth0.com/
AUTH0_API_AUDIENCE=https://web0personal-vector-api.local
CORS_ORIGINS=http://localhost:4321
OPENROUTER_API_KEY=
AGNO_TELEMETRY=false
AGENT_MODEL=openrouter/google/gemini-2.0-flash-001
REQUEST_TIMEOUT_SECONDS=60
# Optional LangWatch tracing (see specs/002-langwatch-backend/quickstart.md)
LANGWATCH_API_KEY=
LANGWATCH_ENDPOINT=
APP_ENVIRONMENT=local

# WhatsApp (optional — backend starts without these; routes not mounted)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
# Local dev only — bypasses HMAC signature checks (never set in production)
WHATSAPP_SKIP_SIGNATURE_VALIDATION=false
