# Copy to project.env and edit for a new app. Every Railway script in this
# folder reads from this file, so no other code edits should be required.

RAILWAY_PROJECT_NAME=my-app

# Railway service names (create them with `railway add --service <name>`)
BACKEND_SERVICE=my-app-backend
FRONTEND_SERVICE=my-app-frontend
POSTGRES_SERVICE=Postgres

# Monorepo paths used by `railway up <dir> --path-as-root`
BACKEND_DIR=apps/backend
FRONTEND_DIR=apps/frontend

# Variable Railway interpolates at deploy time (single-quoted; bash must not expand it)
DATABASE_URL_REF='${{Postgres.DATABASE_URL}}'

# Cross-service URL wiring
BACKEND_CORS_VAR=CORS_ORIGINS
FRONTEND_API_VAR=PUBLIC_AGENTOS_API_BASE_URL

# Smoke test paths appended to each public domain
SMOKE_BACKEND_PATH=/health
SMOKE_FRONTEND_PATH=/

# Local .env keys to push into Railway (space-separated; empty values skipped)
BACKEND_ENV_SYNC_KEYS="AUTH0_DOMAIN AUTH0_ISSUER AUTH0_API_AUDIENCE CORS_ORIGINS OPENROUTER_API_KEY"
FRONTEND_ENV_SYNC_KEYS="PUBLIC_AUTH0_DOMAIN PUBLIC_AUTH0_CLIENT_ID PUBLIC_AUTH0_AUDIENCE PUBLIC_AGENTOS_API_BASE_URL AUTH0_SECRET"

# Defaults applied on every railway-up run (space-separated KEY=VALUE pairs)
BACKEND_DEFAULT_VARS=""
